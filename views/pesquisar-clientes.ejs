<br>


    <form id="meuFormulario">
        <div class="d-flex justify-content-start align-items-center"  >
            
            <input  class="form-control ms-1" type="text" id="termo" name="termo" required placeholder="Pesquise por e-mail ou telefone...">
            <button class="btn btn-primary ms-2" type="submit">Pesquisar!</button>
        </div>
    </form>




    <br>
    <div id="resposta"></div>

    <div class="container">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Telefone</th>
                    <th>Sexo</th>
                    <th>Data de Cadastro</th>
                </tr>
            </thead>
            <tbody id="tabelaCorpo">
                <!-- Os dados da resposta serão inseridos aqui dinamicamente -->
            </tbody>
        </table>
    </div>

    <script>
        const formulario = document.getElementById('meuFormulario');
        const respostaDiv = document.getElementById('resposta');

        formulario.addEventListener('submit', async (e) => {
            e.preventDefault();

            const termo = document.getElementById('termo').value;

            const response = await fetch('/enviar-email', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ termo: termo })
            });

            if (response.ok) {
                const data = await response.json();
                limparTabela();
                preencherTabela(data.data);
                // respostaDiv.textContent = `Resposta da API: ${JSON.stringify(data)}`;
            } else {
                respostaDiv.textContent = 'Erro ao fazer a solicitação.';
            }
        });

       

        function limparTabela() {
            const tabelaCorpo = document.getElementById('tabelaCorpo');
            while (tabelaCorpo.firstChild) {
                tabelaCorpo.removeChild(tabelaCorpo.firstChild);
            }
        }


        function preencherTabela(dados) {
            const tabelaCorpo = document.getElementById('tabelaCorpo');

            for (const item of dados) {
                const newRow = tabelaCorpo.insertRow();
                newRow.innerHTML = `
                    <td>${item.ID}</td>
                    <td>${item.Nome}</td>
                    <td>${item.Email}</td>
                    <td>${item.Telefone}</td>
                    <td>${item.Sexo}</td>
                    <td>${item.DataCadastro}</td>
                `;
            }
        }

        // Chame a função para buscar os dados da API e preencher a tabela
        buscarDadosAPI();
    </script>